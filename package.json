{
  "name": "igreen-dashboard",
  "version": "1.0.0",
  "description": "iGreenMCP Dashboard — Design System with MCP Server for AI-assisted development",
  "main": "index.js",
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./theme/main.css -o ./dist/styles.css --watch",
